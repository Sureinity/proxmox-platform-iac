---
baseline_packages:
  - ca-certificates
  - chrony
  - curl
  - gnupg
  - openssh-server
  - python3
  - python3-apt
  - qemu-guest-agent
  - sudo

baseline_absent_packages:
  - systemd-timesyncd

baseline_services:
  - chrony
  - qemu-guest-agent
  - ssh

baseline_journald_persistent: true

baseline_automation_user: ansible
baseline_automation_user_authorized_keys:
  - "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIExamplePublicKeyOnly operator@example"

baseline_ssh_disable_root_login: true
baseline_ssh_disable_password_login: true

baseline_install_docker: false
baseline_docker_users:
  - ansible
